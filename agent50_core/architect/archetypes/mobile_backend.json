{
  "name": "mobile_backend_archetype",
  "description": "Backend API for mobile applications with push notifications and offline sync",
  "type": "mobile_backend",
  "components": {
    "backend": {
      "framework": "fastapi",
      "language": "python",
      "authentication": "jwt",
      "orm": "sqlalchemy",
      "websockets": true,
      "rate_limiting": true
    },
    "database": {
      "type": "postgres",
      "orm": "sqlalchemy",
      "replication": true,
      "backup": true
    },
    "authentication": {
      "enabled": true,
      "method": "jwt",
      "refresh_tokens": true,
      "device_management": true
    },
    "notifications": {
      "enabled": true,
      "push": true,
      "providers": ["firebase", "apns"],
      "in_app": true
    },
    "file_storage": {
      "enabled": true,
      "provider": "aws_s3",
      "cdn": true,
      "image_processing": true
    },
    "real_time": {
      "enabled": true,
      "websockets": true,
      "presence": true
    }
  },
  "dependencies": {
    "backend": [
      {"name": "fastapi", "version": "0.104.1"},
      {"name": "sqlalchemy", "version": "2.0.23"},
      {"name": "psycopg2-binary", "version": "2.9.9"},
      {"name": "python-jose", "version": "3.3.0"},
      {"name": "passlib", "version": "1.7.4"},
      {"name": "redis", "version": "5.0.1"},
      {"name": "celery", "version": "5.3.4"},
      {"name": "boto3", "version": "1.34.0"},
      {"name": "firebase-admin", "version": "6.2.0"},
      {"name": "pyapns2", "version": "1.1.0"},
      {"name": "websockets", "version": "12.0"},
      {"name": "slowapi", "version": "2.0.0"}
    ]
  },
  "api_endpoints": [
    "/api/v1/auth/login",
    "/api/v1/auth/register",
    "/api/v1/auth/refresh",
    "/api/v1/auth/logout",
    "/api/v1/users/me",
    "/api/v1/users/devices",
    "/api/v1/notifications",
    "/api/v1/notifications/{id}/read",
    "/api/v1/files/upload",
    "/api/v1/files/{id}",
    "/api/v1/ws/connect",
    "/api/v1/health"
  ],
  "database_schema": {
    "tables": [
      {
        "name": "devices",
        "columns": [
          {"name": "id", "type": "uuid", "primary_key": true},
          {"name": "user_id", "type": "uuid", "foreign_key": "users.id"},
          {"name": "device_id", "type": "varchar(255)", "nullable": false},
          {"name": "platform", "type": "varchar(20)", "nullable": false},
          {"name": "push_token", "type": "varchar(500)"},
          {"name": "app_version", "type": "varchar(20)"},
          {"name": "last_seen", "type": "timestamp", "default": "now()"},
          {"name": "is_active", "type": "boolean", "default": true},
          {"name": "created_at", "type": "timestamp", "default": "now()"}
        ],
        "indexes": ["user_id", "device_id"]
      },
      {
        "name": "notifications",
        "columns": [
          {"name": "id", "type": "uuid", "primary_key": true},
          {"name": "user_id", "type": "uuid", "foreign_key": "users.id"},
          {"name": "title", "type": "varchar(200)", "nullable": false},
          {"name": "body", "type": "text", "nullable": false},
          {"name": "data", "type": "jsonb"},
          {"name": "type", "type": "varchar(50)", "nullable": false},
          {"name": "priority", "type": "varchar(10)", "default": "normal"},
          {"name": "delivered", "type": "boolean", "default": false},
          {"name": "read", "type": "boolean", "default": false},
          {"name": "scheduled_for", "type": "timestamp"},
          {"name": "delivered_at", "type": "timestamp"},
          {"name": "created_at", "type": "timestamp", "default": "now()"}
        ]
      }
    ]
  },
  "deployment": {
    "platform": "render",
    "requirements": ["requirements.txt", "Procfile", "runtime.txt"],
    "build_command": "pip install -r requirements.txt",
    "start_command": "gunicorn main:app --bind 0.0.0.0:$PORT --worker-class uvicorn.workers.UvicornWorker",
    "health_check_path": "/health",
    "auto_deploy": true,
    "scale": {"min": 2, "max": 5}
  },
  "env_variables": {
    "required": [
      "DATABASE_URL",
      "SECRET_KEY",
      "REDIS_URL",
      "AWS_ACCESS_KEY_ID",
      "AWS_SECRET_ACCESS_KEY",
      "S3_BUCKET_NAME",
      "FIREBASE_CREDENTIALS_JSON",
      "APNS_KEY_ID",
      "APNS_TEAM_ID",
      "APNS_AUTH_KEY"
    ],
    "optional": [
      "SENTRY_DSN",
      "RATE_LIMIT_PER_MINUTE",
      "CDN_URL",
      "APP_ENVIRONMENT"
    ]
  },
  "api_specifications": {
    "version": "1.0.0",
    "base_path": "/api/v1",
    "authentication": "Bearer Token",
    "rate_limits": {
      "authenticated": "100 requests/minute",
      "public": "10 requests/minute"
    },
    "response_format": {
      "success": {"status": "success", "data": {}},
      "error": {"status": "error", "message": "string", "code": "string"}
    }
  }
}