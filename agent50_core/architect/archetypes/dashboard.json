{
  "name": "dashboard_archetype",
  "description": "Analytics dashboard with real-time data visualization and reporting",
  "type": "dashboard",
  "components": {
    "frontend": {
      "framework": "react",
      "language": "typescript",
      "charts": "recharts",
      "tables": "tanstack-table",
      "state_management": "redux-toolkit",
      "ui_library": "mui",
      "styling": "emotion"
    },
    "backend": {
      "framework": "django",
      "language": "python",
      "rest_framework": "django-rest-framework",
      "orm": "django-orm",
      "caching": "redis",
      "task_queue": "celery"
    },
    "database": {
      "type": "postgres",
      "orm": "django-orm",
      "time_series": false
    },
    "analytics": {
      "enabled": true,
      "real_time": true,
      "data_aggregation": true,
      "export": true,
      "scheduled_reports": true
    },
    "authentication": {
      "enabled": true,
      "method": "session",
      "role_based": true,
      "permissions": true
    }
  },
  "dependencies": {
    "backend": [
      {"name": "django", "version": "4.2.7"},
      {"name": "django-rest-framework", "version": "3.14.0"},
      {"name": "django-cors-headers", "version": "4.2.0"},
      {"name": "psycopg2-binary", "version": "2.9.9"},
      {"name": "redis", "version": "5.0.1"},
      {"name": "celery", "version": "5.3.4"},
      {"name": "django-celery-beat", "version": "2.5.0"},
      {"name": "pandas", "version": "2.1.3"},
      {"name": "numpy", "version": "1.26.0"},
      {"name": "django-filter", "version": "23.3"}
    ],
    "frontend": [
      {"name": "react", "version": "18.2.0"},
      {"name": "react-dom", "version": "18.2.0"},
      {"name": "typescript", "version": "5.3.0"},
      {"name": "@mui/material", "version": "5.14.0"},
      {"name": "@emotion/react", "version": "11.11.0"},
      {"name": "@emotion/styled", "version": "11.11.0"},
      {"name": "@reduxjs/toolkit", "version": "1.9.7"},
      {"name": "react-redux", "version": "8.1.3"},
      {"name": "recharts", "version": "2.9.0"},
      {"name": "@tanstack/react-table", "version": "8.10.0"},
      {"name": "date-fns", "version": "3.0.0"},
      {"name": "axios", "version": "1.6.0"}
    ],
    "database": [
      {"name": "postgresql", "version": "15"}
    ]
  },
  "api_endpoints": [
    "/api/v1/auth/login",
    "/api/v1/auth/logout",
    "/api/v1/dashboard/summary",
    "/api/v1/dashboard/metrics",
    "/api/v1/data/export",
    "/api/v1/data/filter",
    "/api/v1/reports",
    "/api/v1/reports/{id}",
    "/api/v1/users/permissions",
    "/api/v1/ws/updates"
  ],
  "database_schema": {
    "tables": [
      {
        "name": "metrics",
        "columns": [
          {"name": "id", "type": "uuid", "primary_key": true},
          {"name": "name", "type": "varchar(100)", "nullable": false},
          {"name": "value", "type": "decimal(15,4)", "nullable": false},
          {"name": "category", "type": "varchar(50)", "nullable": false},
          {"name": "timestamp", "type": "timestamp", "nullable": false},
          {"name": "dimensions", "type": "jsonb"},
          {"name": "source", "type": "varchar(100)"},
          {"name": "created_at", "type": "timestamp", "default": "now()"}
        ],
        "indexes": ["timestamp", "category"]
      },
      {
        "name": "reports",
        "columns": [
          {"name": "id", "type": "uuid", "primary_key": true},
          {"name": "title", "type": "varchar(200)", "nullable": false},
          {"name": "description", "type": "text"},
          {"name": "type", "type": "varchar(50)", "nullable": false},
          {"name": "parameters", "type": "jsonb"},
          {"name": "schedule", "type": "varchar(50)"},
          {"name": "last_run", "type": "timestamp"},
          {"name": "next_run", "type": "timestamp"},
          {"name": "is_active", "type": "boolean", "default": true},
          {"name": "created_by", "type": "uuid", "foreign_key": "users.id"},
          {"name": "created_at", "type": "timestamp", "default": "now()"}
        ]
      }
    ]
  },
  "deployment": {
    "platform": "render",
    "requirements": ["requirements.txt", "Procfile", "runtime.txt"],
    "build_command": "pip install -r requirements.txt && python manage.py collectstatic --noinput",
    "start_command": "gunicorn config.wsgi:application --bind 0.0.0.0:$PORT",
    "health_check_path": "/health/",
    "auto_deploy": true,
    "static_files": true
  },
  "env_variables": {
    "required": [
      "DATABASE_URL",
      "SECRET_KEY",
      "REDIS_URL",
      "DJANGO_SETTINGS_MODULE",
      "ALLOWED_HOSTS"
    ],
    "optional": [
      "DEBUG",
      "CORS_ALLOWED_ORIGINS",
      "EMAIL_HOST",
      "SENTRY_DSN",
      "AWS_STORAGE_BUCKET_NAME"
    ]
  }
}