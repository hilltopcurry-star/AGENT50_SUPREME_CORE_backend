{
  "name": "ai_app_archetype",
  "description": "AI-powered application with model serving, inference endpoints, and vector databases",
  "type": "ai_app",
  "components": {
    "frontend": {
      "framework": "nextjs",
      "language": "typescript",
      "rendering": "ssr",
      "state_management": "zustand",
      "ui_library": "shadcn/ui",
      "styling": "tailwindcss",
      "realtime": "websockets"
    },
    "backend": {
      "framework": "fastapi",
      "language": "python",
      "ml_framework": "torch",
      "vector_database": "qdrant",
      "embeddings": "sentence-transformers",
      "queue": "celery",
      "caching": "redis"
    },
    "database": {
      "type": "postgres",
      "vector_extension": "pgvector",
      "orm": "sqlalchemy"
    },
    "ai_capabilities": {
      "llm_integration": true,
      "embeddings": true,
      "rag_pipeline": true,
      "fine_tuning": false,
      "model_serving": true
    },
    "file_processing": {
      "enabled": true,
      "supported_formats": ["pdf", "docx", "txt", "md", "html"],
      "ocr": true,
      "chunking": true
    }
  },
  "dependencies": {
    "backend": [
      {"name": "fastapi", "version": "0.104.1"},
      {"name": "torch", "version": "2.1.0"},
      {"name": "transformers", "version": "4.36.0"},
      {"name": "sentence-transformers", "version": "2.2.2"},
      {"name": "langchain", "version": "0.0.340"},
      {"name": "openai", "version": "1.3.0"},
      {"name": "qdrant-client", "version": "1.6.0"},
      {"name": "redis", "version": "5.0.1"},
      {"name": "celery", "version": "5.3.4"},
      {"name": "psycopg2-binary", "version": "2.9.9"},
      {"name": "pgvector", "version": "0.2.0"},
      {"name": "pypdf", "version": "3.17.0"},
      {"name": "python-multipart", "version": "0.0.6"},
      {"name": "boto3", "version": "1.34.0"}
    ],
    "frontend": [
      {"name": "next", "version": "14.0.0"},
      {"name": "react", "version": "18.2.0"},
      {"name": "react-dom", "version": "18.2.0"},
      {"name": "typescript", "version": "5.3.0"},
      {"name": "tailwindcss", "version": "3.3.0"},
      {"name": "axios", "version": "1.6.0"},
      {"name": "react-markdown", "version": "8.0.7"},
      {"name": "react-syntax-highlighter", "version": "15.5.0"},
      {"name": "socket.io-client", "version": "4.7.0"},
      {"name": "react-query", "version": "3.39.3"}
    ],
    "database": [
      {"name": "postgresql", "version": "15"},
      {"name": "pgvector", "version": "0.5.0"}
    ]
  },
  "api_endpoints": [
    "/api/v1/chat/completions",
    "/api/v1/embeddings",
    "/api/v1/documents/upload",
    "/api/v1/documents/{id}",
    "/api/v1/documents/search",
    "/api/v1/models/list",
    "/api/v1/models/load",
    "/api/v1/rag/query",
    "/api/v1/ws/chat",
    "/api/v1/jobs/{job_id}/status"
  ],
  "database_schema": {
    "tables": [
      {
        "name": "documents",
        "columns": [
          {"name": "id", "type": "uuid", "primary_key": true},
          {"name": "filename", "type": "varchar(255)", "nullable": false},
          {"name": "file_type", "type": "varchar(10)", "nullable": false},
          {"name": "file_size", "type": "integer", "nullable": false},
          {"name": "content", "type": "text"},
          {"name": "embedding", "type": "vector(384)"},
          {"name": "metadata", "type": "jsonb"},
          {"name": "user_id", "type": "uuid", "foreign_key": "users.id"},
          {"name": "processed_at", "type": "timestamp"},
          {"name": "created_at", "type": "timestamp", "default": "now()"}
        ]
      },
      {
        "name": "chat_sessions",
        "columns": [
          {"name": "id", "type": "uuid", "primary_key": true},
          {"name": "user_id", "type": "uuid", "foreign_key": "users.id"},
          {"name": "title", "type": "varchar(200)"},
          {"name": "model", "type": "varchar(50)", "nullable": false},
          {"name": "context_window", "type": "integer", "default": 4096},
          {"name": "temperature", "type": "float", "default": 0.7},
          {"name": "created_at", "type": "timestamp", "default": "now()"},
          {"name": "updated_at", "type": "timestamp", "default": "now()"}
        ]
      }
    ]
  },
  "deployment": {
    "platform": "render",
    "requirements": ["requirements.txt", "Procfile", "runtime.txt", "Dockerfile"],
    "build_command": "pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu && pip install -r requirements.txt",
    "start_command": "gunicorn main:app --bind 0.0.0.0:$PORT --workers 2 --timeout 120",
    "health_check_path": "/health",
    "auto_deploy": true,
    "memory_limit": "512MB",
    "cpu_limit": "0.5"
  },
  "env_variables": {
    "required": [
      "DATABASE_URL",
      "SECRET_KEY",
      "OPENAI_API_KEY",
      "REDIS_URL",
      "QDRANT_URL",
      "QDRANT_API_KEY",
      "AWS_ACCESS_KEY_ID",
      "AWS_SECRET_ACCESS_KEY",
      "S3_BUCKET_NAME"
    ],
    "optional": [
      "ANTHROPIC_API_KEY",
      "GOOGLE_API_KEY",
      "COHERE_API_KEY",
      "SENTRY_DSN",
      "MODEL_CACHE_DIR"
    ]
  }
}